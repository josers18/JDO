<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>62.0</apiVersion>
    <isExposed>true</isExposed>
    <masterLabel>Premium Financial Overview</masterLabel>
    <description>Glassmorphic financial overview — live SOQL metrics + sparkline trends, driven by page record context or Flow variables.</description>
    <targets>
        <target>lightning__RecordPage</target>
        <target>lightning__FlowScreen</target>
        <target>lightning__AppPage</target>
        <target>lightning__HomePage</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__RecordPage">
            <property name="trendMonths" type="Integer" default="6" label="Trend window (months)" description="How many months of history to show in sparklines."/>
            <property name="headline" type="String" default="" label="Optional headline"/>
            <objects>
                <object>Account</object>
                <object>Contact</object>
            </objects>
        </targetConfig>
        <targetConfig targets="lightning__FlowScreen">
            <property name="recordId" type="String" label="Record Id"/>
            <property name="trendMonths" type="Integer" default="6" label="Trend window (months)"/>
            <property name="headline" type="String" label="Optional headline"/>
            <property name="overrideDepositsAmount" type="String" label="Override: Deposits amount"/>
            <property name="overrideLoansAmount" type="String" label="Override: Loans amount"/>
            <property name="overrideLoansBalance" type="String" label="Override: Loans balance"/>
            <property name="overrideLoansInterest" type="String" label="Override: Loans interest"/>
            <property name="overrideInvestmentsAmount" type="String" label="Override: Investments amount"/>
            <property name="overrideInvestmentsBalance" type="String" label="Override: Investments balance"/>
            <property name="overrideInvestmentsRoi" type="String" label="Override: Investments ROI (%)"/>
            <property name="overrideDepositsTrend" type="String" label="Override: Deposits trend (CSV, oldest→newest)"/>
            <property name="overrideLoansTrend" type="String" label="Override: Loans trend (CSV, oldest→newest)"/>
            <property name="overrideInvestmentsTrend" type="String" label="Override: Investments trend (CSV, oldest→newest)"/>
        </targetConfig>
        <targetConfig targets="lightning__AppPage,lightning__HomePage">
            <property name="recordId" type="String" label="Record Id (optional)"/>
            <property name="trendMonths" type="Integer" default="6" label="Trend window (months)"/>
        </targetConfig>
    </targetConfigs>
</LightningComponentBundle>
