<apex:page showHeader="false" sidebar="false" standardStylesheets="false" applyHtmlTag="false" applyBodyTag="false">
<!--
  App Launcher bridge for the ReactCommercial UI Bundle.

  UI Bundle apps render only at the Salesforce App Domain (*.my.salesforce.app),
  which cannot be iframed by Lightning Experience: the App Domain sends
  `frame-ancestors 'self'` AND LEX's own `frame-src` CSP omits *.my.salesforce.app.
  A scripted redirect out of the LEX iframe is also blocked (cross-origin
  top-navigation without a user gesture). The ONE thing the browser allows is a
  user-initiated top-level navigation via a clicked `target="_top"` link — so
  this tab is a launch card with a button. (The onload attempt below succeeds in
  contexts that permit it, e.g. opening the page directly; inside LEX the click
  path is the reliable one.)
-->
<html>
<head>
  <title>React Commercial</title>
  <script>
    (function () {
      var target = "https://storm-16a17dc388fbe6--c.demo.my.salesforce.app/app/c__ReactCommercial";
      try { if (window.top === window.self) { window.location.replace(target); } }
      catch (e) { /* framed + cross-origin: fall through to the button */ }
    })();
  </script>
  <style>
    body { margin:0; font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Inter,sans-serif;
           background:#f4f1ea; color:#1e2233; display:flex; align-items:center;
           justify-content:center; min-height:100vh; }
    .card { text-align:center; padding:3rem 3.5rem; background:#fff; border-radius:20px;
            box-shadow:0 18px 50px rgba(30,34,51,0.12); max-width:460px; }
    .badge { font-size:0.72rem; letter-spacing:0.12em; text-transform:uppercase;
             color:#B45309; font-weight:700; }
    h1 { font-size:1.6rem; margin:0.5rem 0 0.35rem; }
    p { color:#5b6172; font-size:0.92rem; line-height:1.5; margin:0 0 1.75rem; }
    a.launch { display:inline-block; background:#B45309; color:#fff; text-decoration:none;
               font-weight:600; font-size:1rem; padding:0.85rem 2rem; border-radius:12px;
               box-shadow:0 6px 18px rgba(180,83,9,0.32); }
    a.launch:hover { background:#92400e; }
  </style>
</head>
<body>
  <div class="card">
    <div class="badge">Cumulus · React on Salesforce</div>
    <h1>React Commercial</h1>
    <p>Commercial banking relationship command center. Opens in the Salesforce App Domain.</p>
    <a class="launch" target="_top"
       href="https://storm-16a17dc388fbe6--c.demo.my.salesforce.app/app/c__ReactCommercial">
      Open React Commercial &#8594;
    </a>
  </div>
</body>
</html>
</apex:page>
