                    label: "Goal Target Amount"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__numberType"
                "personAccountId": object
                    description: |
                      The person account ID.
                    label: "Person Account Id"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__recordIdType"
                                                                        
            outputs:
                "financialGoal": object
                    description: |
                      The created financial goal ID.
                    label: "Financial Goal"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"
                "message": string
                    description: |
                      The financial goal error message.
                    label: "Message"
                    is_displayable: True
                    filter_from_agent: False

        CreateFinancialPlan:
            description: |
                Collect the account ID, name, start date, status, and type. Create a financial plan related to the account.
            label: "Create Financial Plan"
            require_user_confirmation: True
            include_in_progress_indicator: True
            source: "wealthagent__CreateFinancialPlan"
            target: "flow://wealthagent__StdFSCCreaFinclPlan"
                                                                        
            inputs:
                "AccountId": object
                    description: |
                      The account ID used to create a financial plan.
                    label: "Account ID"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__recordIdType"
                "planName": string
                    description: |
                      The name of the financial plan.
                    label: "Plan Name"
                    is_required: True
                    is_user_input: True
                "planStartDate": date
                    description: |
                      The start date of the financial plan.
                    label: "Plan Start Date"
                    is_required: False
                    is_user_input: True
                    complex_data_type_name: "lightning__dateType"
                "planStatus": string
                    description: |
                      The status of the financial plan.
                    label: "Plan Status"
                    is_required: True
                    is_user_input: True
                "planType": string
                    description: |
                      The type of the financial plan.
                    label: "Plan Type"
                    is_required: True
                    is_user_input: True
                                                                        
            outputs:
                "financialPlan": object
                    description: |
                      The created financial plan ID.
                    label: "Financial Plan"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"
                "message": string
                    description: |
                      The financial plan error message.
                    label: "Message"
                    is_displayable: True
                    filter_from_agent: False

        CreatePersonLifeEvent:
            description: |
                Collect the account ID, name, date and type. Create a person life event related to the account.
            label: "Create Person Life Event"
            require_user_confirmation: True
            include_in_progress_indicator: True
            source: "wealthagent__CreatePersonLifeEvent"
            target: "flow://wealthagent__StdFSCCreaPersLifeEvnt"
                                                                        
            inputs:
                "personAccountId": object
                    description: |
                      The ID of the account used to create a person life event.
                    label: "Person Account ID"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__recordIdType"
                "eventName": string
                    description: |
                      The name of the person life event.
                    label: "Event Name"
                    is_required: True
                    is_user_input: True
                "eventDate": object
                    description: |
                      The date and time of the person life event.
                    label: "Event Date"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__dateTimeStringType"
                "eventType": string
                    description: |
                      The type of person life event.
                    label: "Event Type"
                    is_required: True
                    is_user_input: True
                                                                        
            outputs:
                "personLifeEvent": object
                    description: |
                      The created person life event.
                    label: "Person Life Event"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"
                "message": string
                    description: |
                      Stores the person life event error message.
                    label: "Message"
                    is_displayable: True
                    filter_from_agent: False

        CreateActionPlan:
            description: |
                Creates an action plan for a client, leveraging meeting notes if present, or proceeding without them.
            label: "Create Action Plan"
            require_user_confirmation: True
            include_in_progress_indicator: True
            source: "wealthagent__CreateActionPlan"
            target: "flow://wealthagent__StdFSCCreaActnPlan"
                                                                        
            inputs:
