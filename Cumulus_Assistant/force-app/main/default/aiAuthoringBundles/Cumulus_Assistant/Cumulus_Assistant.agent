                    label: "Goal Target Date"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__dateType"
                "goalStatus": string
                    description: |
                      The status of the financial goal.
                    label: "Goal Status"
                    is_required: True
                    is_user_input: True
                "goalType": string
                    description: |
