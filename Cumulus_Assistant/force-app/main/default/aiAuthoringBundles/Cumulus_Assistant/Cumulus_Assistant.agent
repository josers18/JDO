                    label: "Message"
                    is_displayable: True
                    filter_from_agent: False

        CreateActionPlanItem:
            description: |
                Create an action plan item for an action plan. Enter the item name, status, priority, and due date.
            label: "Create Action Plan Item"
            require_user_confirmation: True
            include_in_progress_indicator: True
            source: "wealthagent__CreateActionPlanItem"
            target: "flow://wealthagent__StdFSCCreaActnPlanItem"
                                                                        
            inputs:
