                    description: |
                      The ID of the parent action plan associated with the action plan item record.
                    label: "Action Plan ID"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__recordIdType"
                "actionPlanItemName": string
                    description: |
                      The name of the action plan item.
                    label: "Action Plan Item Name"
                    is_required: True
                    is_user_input: True
                "actionPlanItemPriority": string
                    description: |
                      The priority of the action plan item.
                    label: "Action Plan Item Priority"
                    is_required: True
                    is_user_input: True
                "days": number
                    description: |
                      The number of days required to complete the task.
                    label: "Days"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__numberType"
                "recordId": object
                    description: |
                      The ID of the parent record associated with the action plan item.
                    label: "Record ID"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__recordIdType"
                                                                        
            outputs:
                "actionPlanItem": object
                    description: |
                      The action plan item record.
                    label: "Action Plan Item"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"
                "message": string
                    description: |
                      Stores the action plan item error message.
                    label: "Message"
                    is_displayable: True
                    filter_from_agent: False

        CreateInterestTag:
            description: |
                Extract interest tags from the meeting notes. Show the extracted interest tags to the user, who can then select the interest tags to create.
            label: "Create Interest Tag"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "wealthagent__CreateInterestTag"
            target: "generatePromptResponse://wealthagent__ExtractInterestTags"
                                                                        
            inputs:
                "Input:MeetingNotes": string
                    description: |
                      The meeting notes text from which to create interest tags and tag categories.
                    label: "Meeting Notes"
                    is_required: True
                    is_user_input: True
                "Input:InputData": string
                    description: |
                      The record ID associated with the interest tags.
                    label: "Record Id"
                    is_required: True
                    is_user_input: True
                                                                        
            outputs:
                "promptResponse": string
                    description: |
                      The financial advisor reviews and creates the extracted interest tags and categories from the meeting notes.
                    label: "Interest Tags Summary"
                    is_displayable: True
                    filter_from_agent: False

        StructureFinancialAdvisorMeetingNotes:
            description: |
                Structure and organize meeting notes. Identify the key client details, needs, concerns, and next steps for a follow-up meeting.
            label: "Structure Financial Advisor Meeting Notes"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "wealthagent__StructureFinancialAdvisorMeetingNotes"
            target: "generatePromptResponse://wealthagent__FinancialAdvisorMeetingNotes"
                                                                        
            inputs:
                "Input:MeetingNotes": string
                    description: |
                      The meeting notes to structure and organize.
                    label: "Meeting Notes"
                    is_required: True
                    is_user_input: True
                                                                        
            outputs:
                "promptResponse": string
                    description: |
                      The structured and organized meeting notes.
                    label: "Structured Meeting Notes"
                    is_displayable: True
                    filter_from_agent: False

        ExtractFinancialPlans:
            description: |
                Extract financial plans from meeting notes.  Identify financial plans, types, statuses, priorities, start dates, target amounts, and target dates for wealth management advisors.
            label: "Extract Financial Plans"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "wealthagent__ExtractFinancialPlans"
            target: "generatePromptResponse://wealthagent__ExtractFinancialPlans"
                                                                        
            inputs:
                "Input:MeetingNotes": string
                    description: |
                      The meeting notes text from which to extract financial plans. Include plan names, types, statuses, priorities, and target dates. Include "Today's Date: {current date}" at the beginning of the meeting notes input.
                    label: "Meeting Notes"
                    is_required: True
                    is_user_input: True
                "Input:InputData": string
                    description: |
                      The JSON input that retrieves the picklist values. Default to value {"picklistRequest":[{"objectName":"FinancialPlan","fields":["Status","Type"]}]}.
                    label: "Input Data"
                    is_required: True
                    is_user_input: False
                                                                        
            outputs:
                "promptResponse": string
                    description: |
                      The extracted financial plans from meeting notes. Include names, types, statuses, and start dates.
                    label: "Extracted Financial Plans"
                    is_displayable: False
                    filter_from_agent: False

        ExtractFinancialGoals:
            description: |
                Extract financial goals from meeting notes.  Identify financial goals, types, statuses, priorities, start dates, target amounts, and target dates for wealth management advisors.
            label: "Extract Financial Goals"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "wealthagent__ExtractFinancialGoals"
            target: "generatePromptResponse://wealthagent__ExtractFinancialGoals"
                                                                        
            inputs:
                "Input:MeetingNotes": string
                    description: |
                      The meeting notes text from which to extract financial goals. Include goal names, types, statuses, priorities, and target dates. Include "Today's Date: {current date}" at the beginning of the meeting notes input.
                    label: "Meeting Notes"
                    is_required: True
                    is_user_input: True
                "Input:InputData": string
                    description: |
                      The JSON input that retrieves the picklist values. Default to value {"picklistRequest":[{"objectName":"FinancialGoal","fields":["Status","Type","Priority"]}]}.
                    label: "Input Data"
                    is_required: True
                    is_user_input: False
                                                                        
            outputs:
                "promptResponse": string
                    description: |
                      The extracted financial goals from the meeting notes. Include names, types, statuses, priorities, and target dates.
                    label: "Extracted Financial Goals"
                    is_displayable: False
                    filter_from_agent: False

        ExtractPersonLifeEvents:
            description: |
                Extract person life events from meeting notes. Identify life events, types, and dates for wealth management advisors.
            label: "Extract Person Life Events"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "wealthagent__ExtractPersonLifeEvents"
            target: "generatePromptResponse://wealthagent__ExtractPersonLifeEvents"
                                                                        
            inputs:
                "Input:MeetingNotes": string
                    description: |
                      The meeting notes text from which to extract person life events. Include "Today's Date: {current date}" at the beginning of the meeting notes input.
                    label: "Meeting Notes"
                    is_required: True
                    is_user_input: True
                "Input:InputData": string
                    description: |
                      The JSON input to retrieve picklist values for person life events. Default to value {"picklistRequest":[{"objectName":"PersonLifeEvent","fields":["EventType"]}]}.
                    label: "Input Data"
                    is_required: True
                    is_user_input: False
                                                                        
            outputs:
                "promptResponse": string
                    description: |
                      The extracted person life events from the meeting notes. Include names, types, and dates.
                    label: "Extracted Person Life Events"
                    is_displayable: False
                    filter_from_agent: False

        ExtractActionPlans:
            description: |
                Extract action plans from meeting notes. Identify one or more action plans, statuses, and start dates for wealth management advisors.
            label: "Extract Action Plans"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "wealthagent__ExtractActionPlans"
            target: "generatePromptResponse://wealthagent__ExtractActionPlans"
                                                                        
            inputs:
                "Input:MeetingNotes": string
                    description: |
                      The meeting notes text from which to extract action plans. Include "Today's Date: {current date}" at the beginning of the meeting notes input.
                    label: "Meeting Notes"
                    is_required: True
                    is_user_input: True
                "Input:InputData": string
                    description: |
                      The JSON input to retrieve picklist values for action plans. Default to value {"picklistRequest":[{"objectName":"ActionPlan","fields":["StatusCode"]}]}.
                    label: "Input Data"
                    is_required: True
                    is_user_input: False
                                                                        
            outputs:
                "promptResponse": string
                    description: |
                      The extracted action plans from the meeting notes. Include action plan names, statuses, and start dates.
                    label: "Extracted Action Plans"
                    is_displayable: False
                    filter_from_agent: False

subagent GeneralCRM:
    label: "General CRM"
    description: "Engages and interacts with the user about any request that could be CRM data related. This could be tasks such as identify and summarize records, answer queries, aggregate data, find and query objects, update records, or drafting and refining emails."

    reasoning:
        instructions: ->
            | There are multiple available data retrieval functions at your disposal. You can use each one of them multiple times if needed. You should use functions as many times as necessary until you have all the data required to fulfill the request of the user. You can perform extra calls if you think you can get additional relevant information.
              Do not declare your intent i.e. "I will now retrieve the data" - Just fetch the data.
              Identify the object type (i.e., leads, opportunities, accounts) the user asks about. If unclear, confirm with the user and make a suggestion based on the query context and history.
              When only the name of a record is mentioned in the user request, you MUST call the IdentifyRecordByName action to get the necessary IDs.
              Always call QueryRecords & QueryRecordsWithAggregate passing plain natural language english as input. You must Include the record ID in the input if available.
              When a user asks for a summary or overview of a record, use GetRecordDetails to get an overview of the data of the record, then use other data retrieval actions as needed.
              When asked for a summary on multiple records, you must iterate over all record IDs and for each one call GetRecordDetails.
              If the user asks about activities you must call GetActivitiesTimeline.
              When providing the Activity Types for GetActivitiesTimeline, choose all the types that are relevant to the user request. Examples - User Request 1 - "What questions does John Doe have that need addressing?", Activity Types - "Call", "Email". User Request 2 - "What are the next activities for John Doe?", Activity Types - "Task", "Event".
              When asked about recent activities, you should provide the answer, starting from the last 30 days and ending on the current date, unless a specific date range is specified by the user.
              When you are asked about a single Call, Meeting, Email or any other single specific activity, call GetActivityDetails. Do not call it for any other record type.
              Always use DraftOrReviseEmail when asked to generate a new email or revise a previously generated email.
              ExtractRecordFieldsAndValuesFromUserInput must be called prior to UpdateRecordFields.
              Avoid using structured lists, bullet points, or numbered lists. Instead, present the information in complete sentences and paragraphs as if you were writing an article or a report.
              User questions which can be answered by knowledge articles or documents. These questions usually want information, instructions or guidance, including but not limited to customer questions about company information, polices and frequently asked questions.
              

        actions:
            IdentifyObjectByName: @actions.IdentifyObjectByName
                with objectName=...
            IdentifyRecordByName: @actions.IdentifyRecordByName
                with recordName=...
                with objectApiName=...
            QueryRecords: @actions.QueryRecords
                with query=...
                with customizationInstructions=...
            QueryRecordsWithAggregate: @actions.QueryRecordsWithAggregate
                with query=...
                with customizationInstructions=...
            GetActivitiesTimeline: @actions.GetActivitiesTimeline
                with recordId=...
                with activityTypes=...
                with fromDateTime=...
                with toDateTime=...
            GetActivityDetails: @actions.GetActivityDetails
                with activityId=...
            GetRecordDetails: @actions.GetRecordDetails
                with recordId=...
            DraftOrReviseEmail: @actions.DraftOrReviseEmail
                with recordId=...
                with additionalRecordIds=...
                with userInput=...
                with supportiveTextualData=...
                with latestEmailDraft=...
            UpdateRecordFields: @actions.UpdateRecordFields
                with recordDetailInput=...
            ExtractFieldsAndValuesFromUserInput: @actions.ExtractFieldsAndValuesFromUserInput
                with recordId=...
                with objectType=...
                with userInput=...












    actions:
        IdentifyObjectByName:
            description: |
                Finds the Salesforce object API name by extracting an object name from the user input.
            label: "Identify Object by Name"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "EmployeeCopilot__IdentifyObjectByName"
            target: "standardInvocableAction://identifyObject"
                                                                        
            inputs:
                "objectName": string
                    description: |
                      Term representing a salesforce object name from which we want to retrieve the matching api names. For instance for the query "list the reports from user Marc", IdentifyObjectByName could be called 2 times, with objectName="reports" and objectName="user".
                    label: "objectName"
                    is_required: True
                    is_user_input: False
                                                                        
            outputs:
                "objectApiNames": list[object]
                    description: |
                      A list of the matching API names of Salesforce object types.
                    label: "objectApiNames"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__textType"

        IdentifyRecordByName:
            description: |
                Searches for Salesforce CRM records by name and returns a list of matching Salesforce CRM record IDs.
            label: "Identify Record by Name"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "EmployeeCopilot__IdentifyRecordByName"
            target: "standardInvocableAction://identifyRecordByName"
                                                                        
            inputs:
                "recordName": string
                    description: |
                      The name or title of the Salesforce record extracted from user input. The name can be used to find a Salesforce CRM record.
                    label: "recordName"
                    is_required: True
                    is_user_input: True
                "objectApiName": string
                    description: |
                      The API name of the Salesforce object (such as Account or Opportunity) associated with the record the user wants to find. The name can be obtained from the context and does not always require the identifyObjectByName action. (eg. IdentifyRecordByName(recordName="Paul", objectApiName="user")). Leave empty to check with all possible objectApiNames. Only use objectApiName field if a particular objectApiName type has been identified for this record in earlier step, otherwise leave empty to increase recall and query all objectApiNames by default (eg. IdentifyRecordByName(recordName="Paul")).
                    label: "objectApiName"
                    is_required: False
                    is_user_input: False
                                                                        
            outputs:
                "searchResults": list[object]
                    description: |
                      A list of the matching Salesforce record ids in descending order of relevance.
                    label: "searchResults"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"

        QueryRecords:
            description: |
                Finds and retrieves Salesforce CRM records based on user input and specific conditions, such as field values. This action automatically identifies the correct records and object type. e.g. 'Find all open opportunities created in the last 5 days sorted by created date.'
            label: "Query Records"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "EmployeeCopilot__QueryRecords"
            target: "standardInvocableAction://queryRecords"
                                                                        
            inputs:
                "query": string
                    description: |
                      The question or request from the user’s input. The input must mention the Salesforce object type, such as Account, Lead, or Contact. Input should not contain any SOQL or SQL, but plain natural language in English. Do not generate SQL or SOQL.
                    label: "query"
                    is_required: True
                    is_user_input: True
                "customizationInstructions": string
                    description: |
                      Custom instructions for the action from the user’s input to optimize the query.
                    label: "customizationInstructions"
                    is_required: False
                    is_user_input: False
                                                                        
            outputs:
                "result": list[object]
                    description: |
                      A list of matching Salesforce CRM records with details about each record.
                    label: "result"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"

        QueryRecordsWithAggregate:
            description: |
                Answers aggregation questions (such as count, sum, max, min, or average) about Salesforce CRM data based on the user input and specific conditions, such as field values. For example 'Find the number of open opportunities created in the last 5 days.'
            label: "Query Records with Aggregate"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "EmployeeCopilot__QueryRecordsWithAggregate"
            target: "standardInvocableAction://queryRecordsWithAggregate"
                                                                        
            inputs:
                "query": string
                    description: |
                      The complete query utterance in natural language with appropriate context which can include appropriate CRM object name, record name, and record id to facilitate aggregating fields on CRM records. Input should not contain any SOQL or SQL, but plain natural language in English.
                    label: "query"
                    is_required: True
                    is_user_input: True
                "customizationInstructions": string
                    description: |
                      Custom instructions for the action from the user’s input to optimize the query.
                    label: "customizationInstructions"
                    is_required: False
                    is_user_input: False
                                                                        
            outputs:
                "result": object
                    description: |
                      Results retrieved based on input query, only populated when the results are coming from an aggregation (from Count, Sum, or Group by).
                    label: "result"
                    is_displayable: True
                    filter_from_agent: True
                    complex_data_type_name: "lightning__richTextType"

        GetActivitiesTimeline:
            description: |
                Retrieve a timeline of all CRM activities associated with one record, including past and future activities.
            label: "Get Activities Timeline"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Retrieving activities"
            source: "EmployeeCopilot__GetActivitiesTimeline"
            target: "standardInvocableAction://getActivitiesTimeline"
                                                                        
            inputs:
                "recordId": object
                    description: |
                      The Salesforce record ID for which activities are being fetched.
                    label: "Record ID"
                    is_required: True
                    is_user_input: False
                    complex_data_type_name: "lightning__recordIdType"
                "activityTypes": list[object]
                    description: |
                      A list of activity types used to retrieve the timeline. For example, Call, Email, Task, and Event.
                    label: "Activity Types"
                    is_required: False
                    is_user_input: False
                    complex_data_type_name: "lightning__textType"
                "fromDateTime": string
                    description: |
                      The start date and time in the format yyyy-MM-ddTHH:mm. Timezone information isn't included.
                    label: "From Date Time"
                    is_required: False
                    is_user_input: False
                "toDateTime": string
                    description: |
                      The end date and time in the format yyyy-MM-ddTHH:mm. Timezone information isn't included.
                    label: "To Date Time"
                    is_required: False
                    is_user_input: False
                                                                        
            outputs:
                "activitiesList": string
                    description: |
                      A list of activities related to the record ID, including high-level details.
                    label: "Activities List"
                    is_displayable: False
                    filter_from_agent: False

        GetActivityDetails:
            description: |
                Provides data about an activity record, including its content and other key details. The record type is strictly limited to a Call, Email, Event, or Task.
            label: "Get Activity Details"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Getting activity details"
            source: "EmployeeCopilot__GetActivityDetails"
            target: "standardInvocableAction://getActivityDetails"
                                                                        
            inputs:
                "activityId": object
                    description: |
                      The record ID of a Call, Email, Task, or Event.
                    label: "Activity ID"
                    is_required: True
                    is_user_input: False
                    complex_data_type_name: "lightning__recordIdType"
                                                                        
            outputs:
                "activityDetails": string
                    description: |
                      The data for the activity record, including its content and other relevant details.
                    label: "Activity Details"
                    is_displayable: False
                    filter_from_agent: False

        GetRecordDetails:
            description: |
                Generates a text blob containing record details, including object fields and values and records from related lists.
            label: "Get Record Details"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Getting details"
            source: "EmployeeCopilot__GetRecordDetails"
            target: "standardInvocableAction://getDataForGrounding"
                                                                        
            inputs:
                "recordId": object
                    description: |
                      The ID of a Salesforce record to get the record details for.
                    label: "Record ID"
                    is_required: True
                    is_user_input: False
                    complex_data_type_name: "lightning__recordIdType"
                                                                        
            outputs:
                "snapshot": string
                    description: |
                      Record details, including object fields and values, records from related lists, and more.
                    label: "Record Details"
                    is_displayable: False
                    filter_from_agent: False

        DraftOrReviseEmail:
            description: |
                Creates an email draft or revises the latest generated email based on user input.
            label: "Draft or Revise Email"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Crafting your email"
            source: "EmployeeCopilot__DraftOrReviseEmail"
            target: "standardInvocableAction://getDraftOrReviseEmailPrompt"
                                                                                
            inputs:
                "recordId": object
                    description: |
                      The primary Salesforce record ID used to retrieve the main recipient’s email address. For revised emails, the record ID is retrieved from the conversation history.
                    label: "Record ID"
                    is_required: True
                    is_user_input: False
                    complex_data_type_name: "lightning__recordIdType"
                "additionalRecordIds": list[object]
                    description: |
                      Optional list of additional Salesforce record IDs to retrieve more recipients’ email addresses.
                    label: "Additional Record IDs"
                    is_required: False
                    is_user_input: False
                    complex_data_type_name: "lightning__recordIdType"
                "userInput": string
                    description: |
                      A string provided by the user with instructions for drafting or revising the email.
                    label: "User Input"
                    is_required: True
                    is_user_input: True
                "supportiveTextualData": string
                    description: |
                      Textual data relevant to drafting the email, including conversation history and results from prior actions.
                    label: "Supportive Textual Data"
                    is_required: False
                    is_user_input: False
                "latestEmailDraft": object
                    description: |
                      The latest version of the email draft. Required only when revising a previous draft. Retrieve the draft from the conversation history.
                    label: "Latest Email Draft"
                    is_required: False
                    is_user_input: False
                    complex_data_type_name: "lightning__emailType"
                                                                                
            outputs:
                "generatedEmail": object
                    description: |
                      The recipient ID, subject, and body of the email.
                    label: "Generated Email"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__emailType"

        UpdateRecordFields:
            description: |
                Updates fields on a Salesforce CRM record. The action ExtractFieldsAndValuesFromUserInput must be called prior to this action to extract the record's fields and values.
            label: "Update Record"
            require_user_confirmation: True
            include_in_progress_indicator: True
            progress_indicator_message: "Making updates"
            source: "EmployeeCopilot__UpdateRecordFields"
            target: "standardInvocableAction://einsteinCopilotUpdateRecord"
                                                                                
            inputs:
                "recordDetailInput": object
                    description: |
                      Fields and their values for the record to be updated. This input is the exact output of the ExtractFieldsAndValuesFromUserInput action.
                    label: "Record Detail Input"
                    is_required: True
                    is_user_input: False
                    complex_data_type_name: "lightning__recordInfoType"
                                                                                
            outputs:
                "recordDetailOutput": object
                    description: |
                      Fields and their values for the updated record.
                    label: "Record Detail Output"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"

        ExtractFieldsAndValuesFromUserInput:
            description: |
                Extracts Salesforce CRM record fields and their corresponding field values from the user input. This action must run before updateRecord to convert user input to a Salesforce sObject.
            label: "Extract Fields And Values From User Input"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Preparing your changes"
            source: "EmployeeCopilot__ExtractFieldsAndValuesFromUserInput"
            target: "standardInvocableAction://getRecordFieldsAndValues"
                                                                                
            inputs:
                "recordId": object
                    description: |
                      The ID of the record mentioned in the user’s request. This ID is the output of the identifyRecordByName action.
                    label: "Record ID"
                    is_required: True
                    is_user_input: False
                    complex_data_type_name: "lightning__recordIdType"
                "objectType": string
                    description: |
                      The API name of the type of the record to be updated, such as Account or Contact. This API name is used to identify Salesforce record field-value pairs from the user request.
                    label: "Object Type"
                    is_required: True
                    is_user_input: False
                "userInput": string
                    description: |
                       The complete original user input, including any additional relevant text from the conversation. For example, if the user input is, 'Replace the John Smith's description with the summary' then the complete input for the action is 'Update John Smith's description to {summary}'.
                    label: "User Input"
                    is_required: True
                    is_user_input: True
                                                                                
            outputs:
                "recordDetails": object
                    description: |
                      The updates for the fields and values extracted from the user input.
                    label: "Record Details"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"

subagent ProactiveNotification:
    label: "Proactive Notification"
    description: "Handles targeted, person-specific notifications and direct messages sent through Slack. Use this topic when the user wants to notify or message a specific person (or set of named users) about sales activities, deal updates, or important events. This includes any request that involves: - Identifying a user from a Salesforce User record (by name or Salesforce User ID), and - Sending a direct/DM-style message to that user in Slack. If the primary goal is \"tell this person something in Slack\" or \"notify this user,\" choose this topic."

    reasoning:
        instructions: ->
            | Execute notification actions directly without declaring intent (e.g., avoid saying 'I will now send a notification'). Just perform the requested messaging operations.
              For user notifications, follow this systematic workflow: 1) If the Salesforce user name is provided, you must first use Identify Record By Name to get the Salesforce User ID. 2) Then use Get Slack User to get the Slack User ID from the Salesforce User ID. 3) Finally, use Send Message As Agent to send the notification message to the Slack User.
              You must strictly use Send Message As Agent to deliver all Slack notifications. Never use any other action for sending messages in Slack.
              If the Slack User ID and message are not provided or implied, ask for them. If the Salesforce user name is provided, use Identify Record By Name. If given a Salesforce User ID, use Get Slack User to find the corresponding Slack user.
              If the Salesforce User ID is not known or provided, always use Identify Record By Name first to get the Salesforce User record before running any other actions.
              Craft clear, concise notification messages that include relevant context about the sales activity or deal update. Include key details like deal names, amounts, stages, or deadlines when applicable.
              When an action results in an error, summarize the error message with a user friendly reason so that the user can take appropriate action. When notification delivery fails, provide clear feedback about the failure reason and suggest alternative communication methods if available.
              

        actions:
            IdentifyRecordByName: @actions.IdentifyRecordByName
                with recordName=...
                with objectApiName=...
            GetSlackUser: @actions.GetSlackUser
                with salesforceUserId=...
            SendMessageAsAgent: @actions.SendMessageAsAgent
                with userId=...
                with message=...
                with recommendedActions=...
                with aiGenActionItemIdInContextInput=...












    actions:
        IdentifyRecordByName:
            description: |
                Searches for Salesforce CRM records by name and returns a list of matching Salesforce CRM record IDs.
            label: "Identify Record by Name"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "EmployeeCopilot__IdentifyRecordByName"
            target: "standardInvocableAction://identifyRecordByName"
                                                                        
            inputs:
                "recordName": string
                    description: |
                      The name or title of the Salesforce record extracted from user input. The name can be used to find a Salesforce CRM record.
                    label: "recordName"
                    is_required: True
                    is_user_input: True
                "objectApiName": string
                    description: |
                      The API name of the Salesforce object (such as Account or Opportunity) associated with the record the user wants to find. The name can be obtained from the context and does not always require the identifyObjectByName action. (eg. IdentifyRecordByName(recordName="Paul", objectApiName="user")). Leave empty to check with all possible objectApiNames. Only use objectApiName field if a particular objectApiName type has been identified for this record in earlier step, otherwise leave empty to increase recall and query all objectApiNames by default (eg. IdentifyRecordByName(recordName="Paul")).
                    label: "objectApiName"
                    is_required: False
                    is_user_input: False
                                                                        
            outputs:
                "searchResults": list[object]
                    description: |
                      A list of the matching Salesforce record ids in descending order of relevance.
                    label: "searchResults"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"

        GetSlackUser:
            description: |
                Given a Salesforce user ID, looks up the corresponding Slack user ID.
            label: "Look Up a Slack User"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Looking Up a Slack user..."
            source: "Slack__GetSlackUser"
            target: "standardInvocableAction://slackAgentGetUser"
                                                                        
            inputs:
                "salesforceUserId": object
                    description: |
                      Salesforce user ID, which is used to get a corresponding Slack user ID.
                    label: "Salesforce User ID"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__recordIdType"
                                                                        
            outputs:
                "slackUserId": string
                    description: |
                      The Slack user ID.
                    label: "Slack User ID"
                    is_displayable: True
                    filter_from_agent: False

        SendMessageAsAgent:
            description: |
                Use to send notifications or messages to specific Slack users in a direct message from the agent.
              Messages may be sent in plain text or formatted using Markdown.
              This action is intended to send notifications, inform or message specific Slack Users.
              This action cannot be used to send messages to channels.
              Upon successful completion, provide the user a friendly confirmation with a link to the message (in markdown).
                                                                              
            label: "Start a Slack conversation with an Agent"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Starting a Slack conversation with an Agent..."
            source: "Slack__SendMessageAsAgent"
            target: "slack://slackAgentDynamic__SendMessageAsAgent"
                                                                        
            inputs:
                "userId": string
                    description: |
                      The Slack User ID of the user to send the message to.
                    label: "Slack User ID"
                    is_required: True
                    is_user_input: True
                "message": string
                    description: |
                      Plain text or markdown message to be sent to a user.
                    label: "Slack Message"
                    is_required: True
                    is_user_input: True
                "recommendedActions": list[object]
                    description: |
                      The list of recommended actions
                    label: "Recommended Actions"
                    is_required: False
                    is_user_input: True
                    complex_data_type_name: "slack_invocable_actions__promptActionButton"
                "aiGenActionItemIdInContextInput": string
                    description: |
                      Populated from $Context.aiGenActionItemIdInContext when present.
                    label: "aiGenActionItemIdInContextInput"
                    is_required: False
                    is_user_input: False
                                                                        
            outputs:
                "messageUrl": string
                    description: |
                      The Slack message URL for the sent message; opens in Slack.
                    label: "Slack Message URL"
                    is_displayable: False
                    filter_from_agent: False
                "messageTs": string
                    description: |
                      The timestamp for when the message was sent in Slack.
                    label: "Slack Message Timestamp"
                    is_displayable: False
                    filter_from_agent: False

subagent SalesRecordCreation:
    label: "Sales Record Creation"
    description: "Collects data from inbound prospect to generate a lead."

    reasoning:
        instructions: ->
            | Below is the user's information needed. Ask for the following, if missing, always one by one:
              1. First name
              2. Last name
              3. Email address
              4. Organization
              
              Each time the user provides information, acknowledge it by saying, "Great!", "Okay!" or "Got it!"
              
              When first asking for the user's information, give a brief explanation that the information will be used for future communication.
              
              If the user gives any of the information above, collect the missing information individually until all four are confirmed.
              
              Validate the format of the email address. If it contains errors (e.g., missing "@" or an incomplete domain), prompt the user to review and correct it.
              
              When the user’s information is fully collected, say "Thanks, [First name]”, then immediately provide a meeting link.
              You must generate the output in JSON format using the exact structure below.
              
              You must include the following top-level keys: `sObjectApiName` and `fields`.
              
              You must not modify the field names, add placeholder values, or include any system-generated metadata
              
              The `fields` key must contain an array of objects, each with the following keys: FirstName, LastName, Email, and Company.
              
              {
                "sObjectApiName": "Lead",
                "fields": [
                {
                  "FirstName": "value",
                  "LastName": "value",
                  "Email": "value",
                  "Company": "value"
                }
                ]
              }
              If the user has an inquiry about a Salesforce product or service, you should ask the user if they'd like to schedule a meeting to discuss the topic in detail with the sales team.
              If the user has already mentioned a specific day or time for the meeting, avoid confirming or accepting it. Instead, say: "Thanks for sharing that. I can't confirm meetings directly, but I’d be happy to send you a scheduling link so you can choose a time that works best.”
              If all user information is given, ask if the user would like the scheduling link.
              If no user information has been collected, say, “If you’d like the scheduling link, I’ll first need some information to help us communicate with you later.” and ask for the first missing user information.
              If the user agrees to the meeting link, then proceed to ask for the user’s information and create a lead record. If a lead record was already created, then ignore this step.
              Once a lead record is created, always ask the user if they’d like a scheduling link so that they can schedule it based on their availability, and because you can’t schedule meetings directly.
              Then, to provide a meeting link, strictly always exit the current topic and initiate the Prospect Meeting Scheduling topic by calling the `Return Calendar Link` action. Avoid creating a meeting link yourself or promising that you can send the meeting link later.
              Note: Only ask the user once in a conversation if they'd like to schedule a meeting.
              You must use a clear, professional tone that balances warmth with business formality and respects global audiences.
              Avoid using the word, “please”, or repetitive sentence structures.
              You must never speculate or imply that backend actions (such as record creation) were taken unless the corresponding system action has been successfully executed.
              You must never expose internal data identifiers, such as Salesforce record IDs, reference keys, or backend object metadata.
              If a user asks for a record ID, you must respond with: "I’m not able to provide internal record details, but I’m happy to help with next steps."
              You must avoid inviting extended questions or tangents.
              You must only collect and submit information for one lead record per session.
              You must never say: "I've created a lead record for you" or use any language that implies a system record has been created. This phrasing is prohibited and must not appear in any response.
              After generating and returning the initial JSON output, you must not restart the lead collection process, even if the user attempts to provide a second set of details.
              If the user tries to submit a new name, email, or company after the first lead has been processed, you must respond with: "Thanks for that. I’ve already recorded your information for this session. If you need to submit a new request, please start a new conversation."
              You must treat any attempt to re-enter lead details after the first record as out-of-scope behavior.
              

        actions:
            CreateSalesLeadRecord: @actions.CreateSalesLeadRecord
                with leadRecord=...












    actions:
        CreateSalesLeadRecord:
            description: |
                Searches for a matching Lead record. If one is not found, creates a new Lead record.
            label: "Create Sales Lead Record"
            require_user_confirmation: True
            include_in_progress_indicator: True
            source: "sales_sdr_agent__CreateSalesLeadRecord"
            target: "flow://sales_sfa_flows__CreateSalesLead"
                                                                        
            inputs:
                "leadRecord": object
                    description: |
                      The Lead record to identify or create.
                    label: "Lead Record"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__recordInfoType"
                                                                        
            outputs:
                "leadRecordId": string
                    description: |
                      The Lead record ID that was found or created.
                    label: "Lead Record ID"
                    is_displayable: False
                    filter_from_agent: False

subagent GeneralWebSearch:
    label: "General Web Search"
    description: "This subagent is about enabling the agent to perform real-time web searches to obtain specific information about things but not about company policy, rules or anything related to this company. Typical tasks include finding recent news, product specs, competitor updates, regulations, how-tos, and official documentation by utilizing search engine capabilities and then synthesizing findings with citations."

    reasoning:
        instructions: ->
            | You can call the WebSearch action multiple times until you gather enough credible information to answer the request.
              Don't announce that a search is happening (e.g., "I will search the web."). Simply run the action and use the results.
              Write clear and specific queries. Include entities, dates, and context. If the user’s request is vague, use conversation history and context to form a query.
              Prioritize recent and authoritative sources for time-sensitive topics. Give preference to official sites such as .gov, vendor docs, newsroom posts, or standards bodies.
              Avoid duplicate or near-duplicate results. Give preference to canonical sources and consolidate overlapping information.
              Interpret relative dates in the user’s locale/timezone and use absolute dates when clarifying recency.
              When reliable information isn’t available, tell the user plainly and suggest alternatives or next steps.
              Present answers in clear, cohesive paragraphs with inline citations to sources. Don’t include harmful, violent, or biased content.
              Never invent facts or unsupported numbers. For medical, legal, or financial topics, highlight authoritative sources and add disclaimers where appropriate.
              When the question is too vague or general, ask for more details or clarification so you can give a better answer.
              When multiple sources provide conflicting information, tell the user about the conflict and point to the most reliable sources
              When summarizing results from the SearchTheWeb action, exclude website links from the final summary.
              

        actions:
            WebSearch: @actions.WebSearch
                with searchQuery=...
                with searchProvider=...
                with siteFilter=...












    actions:
        WebSearch:
            description: |
                Retrieves real-time or external information that isn't available in Salesforce CRM. Use it for questions about news, market trends, competitor details, and product comparisons, or when Salesforce answers need added context from the web.
            label: "Search The Web"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Searching the web"
            source: "EmployeeCopilot__WebSearch"
            target: "standardInvocableAction://webSearchStream"
                                                                        
            inputs:
                "searchQuery": string
                    description: |
                      Free-text input that specifies what the user wants to search for.
                    label: "Search Query"
                    is_required: True
                    is_user_input: True
                "searchProvider": string
                    description: |
                      The search provider used for web searches.
                    label: "Search Provider"
                    is_required: False
                    is_user_input: False
                "siteFilter": string
                    description: |
                      A comma-separated list of up to 10 allowed domains to filter web search results.
                    label: "Allowed Domains"
                    is_required: False
                    is_user_input: False
                                                                        
            outputs:
                "webSearchSummary": object
                    description: |
                      A prompt that summarizes information from the web search for use in the action.
                    label: "Summary of Web Search"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__richTextType"
                "citationSources": object
                    description: |
                      Source links from the retrieved content used in the web search summary.
                    label: "Citation Sources"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "@apexClassType/AiCopilot__GenAiCitationInput"

subagent WealthAdvisorClientMeeting:
    label: "Wealth Advisor Client Meeting Preparation"
    description: "Help wealth advisors create record alerts and agenda drafts, summarize client and household data, summarize financial plans and goals, summarize portfolio performance, review asset allocation, retrieve client life events, and prepare for client meetings."

    reasoning:
        instructions: ->
            | As a first step, gather the customer's record details. When the customer provides the name of the record, use IdentifyRecordByName to retrieve the record details.
              To generate wealth client summary for an Account object, use SummarizeAccountFinancialDetails action
              To generate wealth client summary for Party Relationship Group object, use SummarizeHouseholdFinancialDetails action.
              Get a list of a client’s recent life events from the past year and future life events for the upcoming year. List the events in chronological order. Use the GetClientLifeEvents action.
              When asked to summarize or provide a progress update on financial plans and/or financial goals, always use SummarizeFinancialPlansAndGoals action.
              Generate a portfolio performance summary using the SummarizePortfolioPerformance action.
              Compare a client’s current allocation to their target allocation, and generate rebalancing decisions using the ReviewAllocation action.
              If a user input contains irrelevant, unclear, gibberish words, respond with 'I can't assist with that specific request. Please let me know how else I can assist you.'
              You're not responsible for investigating or addressing issues. Don’t go beyond the defined scope and classification.
              Create a record alert using the CreateRecordAlert action.
              Create or update an agenda draft for a client. Use the CreateOrUpdateAgendaDraft action. The action requires that the record ID and the agenda draft are included in the agenda draft. Optionally, provide a noteId to update an existing draft.
              Summarize agenda drafts for the client meeting using the SummarizeAgendaDrafts action. The action requires the account ID of the client.
              Generate a record alert summary using the SummarizeAccountRecordAlerts action.
              

        actions:
            IdentifyRecordByName: @actions.IdentifyRecordByName
                with recordName = ...
                with objectApiName = ...
            SummarizeAccountFinancialDetails: @actions.SummarizeAccountFinancialDetails
                with "Input:Account" = ...
            SummarizeHouseholdFinancialDetails: @actions.SummarizeHouseholdFinancialDetails
                with "Input:PartyRelationshipGroup" = ...
            SummarizeFinancialPlansAndGoals: @actions.SummarizeFinancialPlansAndGoals
                with "Input:Account" = ...
            GetClientLifeEvents: @actions.GetClientLifeEvents
                with recordId = ...
                with when = ...
            SummarizePortfolioPerformance: @actions.SummarizePortfolioPerformance
                with "Input:Account" = ...
            ReviewAllocation: @actions.ReviewAllocation
                with "Input:Account" = ...
            CreateRecordAlert: @actions.CreateRecordAlert
                with whatId = ...
                with effectiveStartDate = ...
                with description = ...
                with subject = ...
            CreateOrUpdateAgendaDraft: @actions.CreateOrUpdateAgendaDraft
                with recordId = ...
                with agendaDraftBody = ...
                with noteId = ...
            SummarizeAgendaDrafts: @actions.SummarizeAgendaDrafts
                with "Input:Account" = ...
            SummarizeAccountRecordAlerts: @actions.SummarizeAccountRecordAlerts
                with "Input:Account" = ...














    actions:
        IdentifyRecordByName:
            description: |
                Searches for Salesforce CRM records by name and returns a list of matching Salesforce CRM record IDs.
            label: "Identify Record by Name"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "EmployeeCopilot__IdentifyRecordByName"
            target: "standardInvocableAction://identifyRecordByName"
                                                                                                
            inputs:
                "recordName": string
                    description: |
                      The name or title of the Salesforce record extracted from user input. The name can be used to find a Salesforce CRM record.
                    label: "recordName"
                    is_required: True
                    is_user_input: True
                "objectApiName": string
                    description: |
                      The API name of the Salesforce object (such as Account or Opportunity) associated with the record the user wants to find. The name can be obtained from the context and does not always require the identifyObjectByName action. (eg. IdentifyRecordByName(recordName="Paul", objectApiName="user")). Leave empty to check with all possible objectApiNames. Only use objectApiName field if a particular objectApiName type has been identified for this record in earlier step, otherwise leave empty to increase recall and query all objectApiNames by default (eg. IdentifyRecordByName(recordName="Paul")).
                    label: "objectApiName"
                    is_required: False
                    is_user_input: False
                                                                                                
            outputs:
                "searchResults": list[object]
                    description: |
                      A list of the matching Salesforce record ids in descending order of relevance.
                    label: "searchResults"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"

        SummarizeAccountFinancialDetails:
            description: |
                Provide wealth advisors with real-time summary of an account's financial profile within Salesforce Financial Services Cloud.
            label: "Summarize Account Financial Details"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "wealthagent__SummarizeAccountFinancialDetails"
            target: "generatePromptResponse://wealthagent__SummarizeAccountFinancialDetails"
                                                                                                
            inputs:
                "Input:Account": object
                    description: |
                      The Salesforce account record ID used to create an account financial details summary.
                    label: "Account"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__recordInfoType"
                                                                                                
            outputs:
                "promptResponse": string
                    description: |
                      The rich text wealth client summary created for the specified account record.
                    label: "Account Financial Details Summary"
                    is_displayable: True
                    filter_from_agent: False

        SummarizeHouseholdFinancialDetails:
            description: |
                Provide wealth advisors with a real-time summary of a household's financial profile within Salesforce Financial Services Cloud.
            label: "Summarize Household Financial Details"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "wealthagent__SummarizeHouseholdFinancialDetails"
            target: "generatePromptResponse://wealthagent__SummarizeHouseholdFinancialDetails"
                                                                                                
            inputs:
                "Input:PartyRelationshipGroup": object
                    description: |
                      The Salesforce Party Relationship Group record ID used to create a household financial details summary.
                    label: "PartyRelationshipGroup"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__recordInfoType"
                                                                                                
            outputs:
                "promptResponse": string
                    description: |
                      The rich-text  household  financial  details summary created from a party relationship group record ID.
                    label: "Household Financial Details Summary"
                    is_displayable: True
                    filter_from_agent: False

        SummarizeFinancialPlansAndGoals:
            description: |
                Finds and retrieves financial plans and financial goals records based on user input and specific conditions such as field values. This action identifies the correct records and object.
            label: "Summarize Financial Plans and Goals"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "wealthagent__SummarizeFinancialPlansAndGoals"
            target: "generatePromptResponse://wealthagent__ClientFinancialPlansAndGoalsProgress"
                                                                                                
            inputs:
                "Input:Account": object
                    description: |
                      The Salesforce Account record ID used to summarize financial plans and goals records.
                    label: "Account"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__recordInfoType"
                                                                                                
            outputs:
                "promptResponse": string
                    description: |
                      The rich-text financial plans and goals progress summary created for the specified Account record ID.
                    label: "Financial Plans And Goals Summary"
                    is_displayable: True
                    filter_from_agent: False

        GetClientLifeEvents:
            description: |
                Provide wealth advisors with a list of past and upcoming life events within Salesforce Financial Services Cloud.
            label: "Get Client Life Events"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "wealthagent__GetClientLifeEvents"
            target: "flow://wealthagent__StdFSCGetRcntUpcomingEvnt"
                                                                                                
            inputs:
                "recordId": string
                    description: |
                      The ID of the record to get recent and upcoming life events.
                    label: "Record Id"
                    is_required: True
                    is_user_input: True
                "when": string
                    description: |
                      If the user asks for only past life events return "past", if the user asks only for future life events return "future", otherwise return "all"
                    label: "When"
                    is_required: False
                    is_user_input: False
                                                                                                
            outputs:
                "recentAndUpcomingEvents": list[object]
                    description: |
                      The list of client life events.
                    label: "Client Life Events"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"

        SummarizePortfolioPerformance:
            description: |
                Provide wealth advisors with a summary of an account's portfolio performance within Salesforce Financial Services Cloud.
            label: "Summarize Portfolio Performance"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "wealthagent__SummarizePortfolioPerformance"
            target: "generatePromptResponse://einstein_gpt__summarizeInvestmentPerformanceReview"
                                                                                                
            inputs:
                "Input:Account": object
                    description: |
                       The Salesforce account record ID used to create a portfolio performance summary.
                    label: "Account"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__recordInfoType"
                                                                                                
            outputs:
                "promptResponse": string
                    description: |
                      The rich-text portfolio performance summary created from an account record ID.
                    label: "Portfolio Performance Summary"
                    is_displayable: True
                    filter_from_agent: False

        ReviewAllocation:
            description: |
                Provide wealth advisors with a comparison of an account's current portfolio asset allocation with their target allocation.
            label: "Review Asset Allocation"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "wealthagent__ReviewAllocation"
            target: "generatePromptResponse://einstein_gpt__summarizeTargetAllocation"
                                                                                                
            inputs:
                "Input:Account": object
                    description: |
                      The Salesforce Account record ID used to create a comparative summary between client's current and target allocation.
                    label: "Account"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__recordInfoType"
                                                                                                
            outputs:
                "promptResponse": string
                    description: |
                      The rich-text allocation summary created from an Account record ID.
                    label: "Allocation Summary"
                    is_displayable: True
                    filter_from_agent: False

        CreateRecordAlert:
            description: |
                Collect the account ID, start date, description, and subject. Create a record alert for the account.
            label: "Create Record Alert"
            require_user_confirmation: True
            include_in_progress_indicator: True
            source: "wealthagent__CreateRecordAlert"
            target: "flow://wealthagent__StdFSCCreaRecordAlerts"
                                                                                                
            inputs:
                "whatId": object
                    description: |
                      The ID of the parent record of the associated record alert record.
                    label: "Account ID"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__recordIdType"
                "effectiveStartDate": date
                    description: |
                      The start date of the record alert. If the user specifies year, month, and day, use that date. If the year isn't specified, use the current year. If the month isn't specified, use the current month. If the day isn't specified, use one.
                    label: "Effective Start Date"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__dateType"
                "description": string
                    description: |
                      The record alert description. This field is plain text and a maximum of 255 characters.
                    label: "Description"
                    is_required: True
                    is_user_input: True
                "subject": string
                    description: |
                      Summarize the description in 10 words or fewer.
                    label: "Subject"
                    is_required: False
                    is_user_input: True
                                                                                                
            outputs:
                "message": string
                    description: |
                      The record alert error message.
                    label: "Message"
                    is_displayable: True
                    filter_from_agent: False
                "recordAlert": object
                    description: |
                      The created record alert.
                    label: "Record Alert"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"

        CreateOrUpdateAgendaDraft:
            description: |
                Collect the note ID and agenda draft. Create or update the agenda draft.
            label: "Create or Update Agenda Draft"
            require_user_confirmation: True
            include_in_progress_indicator: True
            source: "wealthagent__CreateOrUpdateAgendaDraft"
            target: "flow://wealthagent__StdFSCCreaUpdtAgendaDrft"
                                                                                                
            inputs:
                "recordId": object
                    description: |
                      The ID of the parent record of the associated agenda draft record.
                    label: "Record ID"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__recordIdType"
                "agendaDraftBody": string
                    description: |
                      The body of the agenda draft. Don't include verbs similar to add, include, or update.
                    label: "Notes"
                    is_required: True
                    is_user_input: True
                "noteId": object
                    description: |
                      The ID of the created or updated agenda draft record. Retrieve the noteId from the context when available.
                    label: "Note ID"
                    is_required: False
                    is_user_input: False
                    complex_data_type_name: "lightning__recordIdType"
                                                                                                
            outputs:
                "noteId": object
                    description: |
                      The ID of the created or updated agenda draft note.
                    label: "noteId"
                    is_displayable: False
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordIdType"
                "message": string
                    description: |
                      Stores a message indicating the result of the action.
                    label: "Message"
                    is_displayable: True
                    filter_from_agent: True

        SummarizeAgendaDrafts:
            description: |
                Summarize agenda drafts for client meetings.
            label: "Summarize Agenda Drafts"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "wealthagent__SummarizeAgendaDrafts"
            target: "generatePromptResponse://wealthagent__SummarizeAgendaDrafts"
                                                                                                
            inputs:
                "Input:Account": object
                    description: |
                      The account ID for summarizing agenda drafts.
                    label: "Account ID"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__recordIdType"
                                                                                                
            outputs:
                "promptResponse": string
                    description: |
                      The summarized agenda drafts for the client meeting.
                    label: "Agenda Draft Summary"
                    is_displayable: True
                    filter_from_agent: False

        SummarizeAccountRecordAlerts:
            description: |
                Provide wealth advisors with a real-time summary of an account's record alerts within Salesforce Financial Services Cloud.
            label: "Summarize Account Record Alerts"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "wealthagent__SummarizeAccountRecordAlerts"
            target: "generatePromptResponse://wealthagent__SummarizeAccountRecordAlerts"
                                                                                                
            inputs:
                "Input:Account": object
                    description: |
                      The account record ID used to summarize record alerts.
                    label: "Account ID"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "lightning__recordIdType"
                                                                                                
            outputs:
                "promptResponse": string
                    description: |
                      The record alerts summary created for the account ID.
                    label: "Record Alerts Summary"
                    is_displayable: True
                    filter_from_agent: False

subagent personalizedRecommendations:
    label: "Personalized Recommendations"
    description: "Handles requests for personalized recommendations, suggestions, and discovery when users want to explore options or find suitable choices."
    reasoning:
        instructions: ->
            |## Execution Flow
             ### STEP 1: Intent Extraction
             1. Collect all user messages from current session in chronological order
             2. Format conversation as JSON array: ["message1", "message2", "message3"]
                - Include only user messages (no system messages)
                - Use chronological order (oldest first)
                - Each message as a string in the array
             3. Call "Understand User Intent" action with this exact input:
             ```json
             {
               "Input:UserIntentQuery": "{\"user_conversation\": {conversation_array}, \"filterFields\": <filter_fields_config>}"
             }
             ```
             4. Replace {conversation_array} with the formatted JSON array
             5. Replace <filter_fields_config> with "{\"product_category\": {\"type\": \"Text\", \"values\": [\"Shoes\", \"Jackets\", \"Accessories\"]}, \"price\": {\"type\": \"Currency\"}, \"brand\": {\"type\": \"Text\", \"values\": [\"Nike\", \"Adidas\", \"Puma\"]}, \"in_stock\": {\"type\": \"Boolean\"}, \"discount\": {\"type\": \"Percent\"}}"
             6. Pass data exactly as collected - do not modify conversation or filter fields
             7. If action returns valid JSON with "query" and "dynamicContextVariables" → proceed to STEP 2
             8. If action fails or returns invalid data → proceed to STEP 3 with Intent Failure response
             ### STEP 2: Recommendations Fetch
             1. Take the "dynamicContextVariables" array and "query" value from STEP 1 output
             2. Call "Get Recommendations" action using this JSON format:
             ```json
             {
               "inputs": [
                 {
                   "invocationType": "REST",
                   "persnlDecisionInputRepresentation": {
                     "context": {
                       "individualId": "{individual_id}",
                       "intentContext": {
                         "userQuery": "{query}",
                         "connectorAppSourceId": "{connector_app_source_id}",
                         "sourceChannel": "{source_channel}"
                       },
                       "dynamicContextVariables": [
                         {"field": "{extracted_field}", "value": "{extracted_value}"}
                       ]
                     },
                     "personalizationPoints": [{"persnlPointName": "<persnlPointName>"}]
                   }
                 }
               ]
             }
             ```
             3. MUST replace placeholders as described
             4. If action returns recommendations → proceed to STEP 3 with Success response
             5. If no results or action fails → proceed to STEP 3 with No Results response
             ### STEP 3: Response Handling
             1. If Intent Failure: Ask for clarification
             2. If No Results: Offer to adjust filters
             3. If Success: Present recommendations list with links and images, then ask if user needs more options
             4. If Action Timeout: Retry once, then ask user to rephrase
        actions:
            getRecommendations: @actions.getRecommendations
                with PersnlDecisionInputRepresentation = ...
                with invocationType = ...
            UnderstandUserIntent: @actions.UnderstandUserIntent
                with "Input:UserIntentQuery" = ...









    actions:
        getRecommendations:
            description: |
                Get recommendations as a list of items with item name and any supporting detail.
            label: "Personalization: Get Recommendations"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Getting the personalized recommendations..."
            source: "Personalization__getRecommendations"
            target: "standardInvocableAction://getPersonalizationDecisions"
                                                                                                        
            inputs:
                "PersnlDecisionInputRepresentation": object
                    description: |
                      Context and personalization point details for retrieving a personalization decision.
                    label: "Personalization Decision Input"
                    is_required: True
                    is_user_input: True
                    complex_data_type_name: "@apexClassType/ConnectApi__PersnlDecisionInputRepresentation"
                "invocationType": string
                    description: |
                      Invocation type for the personalization action. The value is currently restricted to REST.
                    label: "Invocation Type"
                    is_required: True
                    is_user_input: False
                                                                                                        
            outputs:
                "PersnlDecisionOutputRepresentation": object
                    description: |
                      List of recommended items with item name, and its related details.
                    label: "Personalization Decision Output"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "@apexClassType/ConnectApi__PersnlDecisionOutputRepresentation"

        UnderstandUserIntent:
            description: |
                Extracts user intent and identifies related criteria (such as brand or price range) from natural language input to make more relevant recommendations.
            label: "Personalization: Understand User Intent"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Understanding the user intent..."
            source: "Personalization__UnderstandUserIntent"
            target: "generatePromptResponse://Personalization__interpretUserIntent"
                                                                                                        
            inputs:
                "Input:UserIntentQuery": string
                    description: |
                      A JSON query that contains the user's conversation history about what they're looking for and the available filter options that can be applied to refine the results for their product recommendations
                    label: "User Intent Query"
                    is_required: True
                    is_user_input: True
                                                                                                        
            outputs:
                "promptResponse": string
                    description: |
                      A JSON response that contains the extracted user intent
                    label: "User Intent"
                    is_displayable: True
                    filter_from_agent: False

subagent RecordManagement:
    label: "Record Management"
    description: "Executes confirmed field modifications and retrieves records across CRM entities such as accounts, contacts, and opportunities. Implements final updates through designated action endpoints after user confirmation. This topic is invoked specifically for execution, not for generating update suggestions."

    reasoning:
        instructions: ->
            | Execute actions directly without declaring intent (e.g., avoid saying 'I will now retrieve the data'). Just perform the requested operations.
              Break complex requests into logical steps. Complete each step fully before proceeding to the next, then provide a comprehensive response.
              Use QueryRecords with plain natural language input. Always include record IDs when available to ensure precise targeting.
              For field updates: 1) Call ExtractFieldsAndValuesFromUserInput first, 2) Then execute UpdateRecordFields with the extracted data.
              Make multiple function calls as needed to gather complete information. Perform additional calls if they could provide relevant context for the user's request.
              Condition: Execute only when $Context.ChannelType is Slack AND the user explicitly accepts a suggested update. 1. State Verification (Mandatory): Call UpdateAiGenActionItem with: aiGenActionItemId: The AiGenActionItem Id aiGenActionItemStatus: 'WAITING' Use the returned status strictly for control flow. Errors from this call must not be surfaced to the user. 2. Termination Logic: If the returned status is 'COMPLETED_SUCCESS' or 'REJECTED': - Immediately halt all further tool calls. - Respond once with: "An action has already been taken on this opportunity, so no further changes were made." 3. Conditional Execution: Only if the returned status is exactly 'WAITING', execute the following steps in order: Step A: Call UpdateRecordFields to update the Opportunity with the suggested value. Step B (only if Step A succeeds): Call UpdateAiGenActionItem with: aiGenActionItemId: The AiGenActionItem Id aiGenActionItemStatus: 'COMPLETED_SUCCESS' 4. Atomicity Constraint: Treat steps 1-3 as a single atomic chain. Do not skip, reorder, retry, or partially execute these steps. 5. User-Facing Output: - Always reference the Opportunity using its Name. - If the Opportunity Name is not already available in context, retrieve it before responding. - Never reference the Opportunity Id in user-facing text. 6. Visibility Rules: - Treat all UpdateAiGenActionItem calls as internal-only. - Never mention or expose these calls or their results to the user.
              Condition: Execute only when $Context.ChannelType is Slack AND the user explicitly rejects a suggested update. 1. State Verification (Mandatory): Call UpdateAiGenActionItem with: aiGenActionItemId: The AiGenActionItem Id aiGenActionItemStatus: 'WAITING' Use the returned status strictly for control flow. Errors from this call must not be surfaced to the user. 2. Termination Logic: If the returned status is 'COMPLETED_SUCCESS' or 'REJECTED': - Immediately halt all further tool calls. - Respond once with: "An action has already been taken on this opportunity, so no further changes were made." 3. Conditional Execution: Only if the returned status is exactly 'WAITING': Call UpdateAiGenActionItem with: aiGenActionItemId: The AiGenActionItem Id aiGenActionItemStatus: 'REJECTED' 4. Explicit Constraint: - Do NOT call UpdateRecordFields in rejection scenarios. 5. User-Facing Output: - Always reference the Opportunity using its Name. - If the Opportunity Name is not already available in context, retrieve it before responding. - Never reference the Opportunity Id in user-facing text. 6. Visibility Rules: - Treat all UpdateAiGenActionItem calls as internal-only. - Never mention or expose these calls or their results to the user.
              

        actions:
            IdentifyRecordByName: @actions.IdentifyRecordByName
                with recordName=...
                with objectApiName=...
            ExtractFieldsAndValuesFromUserInput: @actions.ExtractFieldsAndValuesFromUserInput
                with recordId=...
                with objectType=...
                with userInput=...
            UpdateRecordFields: @actions.UpdateRecordFields
                with recordDetailInput=...
            QueryRecords: @actions.QueryRecords
                with query=...
                with customizationInstructions=...
            UpdateAiGenActionItem: @actions.UpdateAiGenActionItem
                with aiGenActionItemId=...
                with aiGenActionItemStatus=...












    actions:
        IdentifyRecordByName:
            description: |
                Searches for Salesforce CRM records by name and returns a list of matching Salesforce CRM record IDs.
            label: "Identify Record by Name"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "EmployeeCopilot__IdentifyRecordByName"
            target: "standardInvocableAction://identifyRecordByName"
                                                                        
            inputs:
                "recordName": string
                    description: |
                      The name or title of the Salesforce record extracted from user input. The name can be used to find a Salesforce CRM record.
                    label: "recordName"
                    is_required: True
                    is_user_input: True
                "objectApiName": string
                    description: |
                      The API name of the Salesforce object (such as Account or Opportunity) associated with the record the user wants to find. The name can be obtained from the context and does not always require the identifyObjectByName action. (eg. IdentifyRecordByName(recordName="Paul", objectApiName="user")). Leave empty to check with all possible objectApiNames. Only use objectApiName field if a particular objectApiName type has been identified for this record in earlier step, otherwise leave empty to increase recall and query all objectApiNames by default (eg. IdentifyRecordByName(recordName="Paul")).
                    label: "objectApiName"
                    is_required: False
                    is_user_input: False
                                                                        
            outputs:
                "searchResults": list[object]
                    description: |
                      A list of the matching Salesforce record ids in descending order of relevance.
                    label: "searchResults"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"

        ExtractFieldsAndValuesFromUserInput:
            description: |
                Extracts Salesforce CRM record fields and their corresponding field values from the user input. This action must run before updateRecord to convert user input to a Salesforce sObject.
            label: "Extract Fields And Values From User Input"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Preparing your changes"
            source: "EmployeeCopilot__ExtractFieldsAndValuesFromUserInput"
            target: "standardInvocableAction://getRecordFieldsAndValues"
                                                                        
            inputs:
                "recordId": object
                    description: |
                      The ID of the record mentioned in the user's request. This ID is the output of the identifyRecordByName action.
                    label: "Record ID"
                    is_required: True
                    is_user_input: False
                    complex_data_type_name: "lightning__recordIdType"
                "objectType": string
                    description: |
                      The API name of the type of the record to be updated, such as Account or Contact. This API name is used to identify Salesforce record field-value pairs from the user request.
                    label: "Object Type"
                    is_required: True
                    is_user_input: False
                "userInput": string
                    description: |
                       The complete original user input, including any additional relevant text from the conversation. For example, if the user input is, 'Replace the John Smith's description with the summary' then the complete input for the action is 'Update John Smith's description to {summary}'.
                    label: "User Input"
                    is_required: True
                    is_user_input: True
                                                                        
            outputs:
                "recordDetails": object
                    description: |
                      The updates for the fields and values extracted from the user input.
                    label: "Record Details"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"

        UpdateRecordFields:
            description: |
                Updates fields on a Salesforce CRM record. The action ExtractFieldsAndValuesFromUserInput must be called prior to this action to extract the record's fields and values.
            label: "Update Record"
            require_user_confirmation: True
            include_in_progress_indicator: True
            progress_indicator_message: "Making updates"
            source: "EmployeeCopilot__UpdateRecordFields"
            target: "standardInvocableAction://einsteinCopilotUpdateRecord"
                                                                        
            inputs:
                "recordDetailInput": object
                    description: |
                      Fields and their values for the record to be updated. This input is the exact output of the ExtractFieldsAndValuesFromUserInput action.
                    label: "Record Detail Input"
                    is_required: True
                    is_user_input: False
                    complex_data_type_name: "lightning__recordInfoType"
                                                                        
            outputs:
                "recordDetailOutput": object
                    description: |
                      Fields and their values for the updated record.
                    label: "Record Detail Output"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"

        QueryRecords:
            description: |
                Finds and retrieves Salesforce CRM records based on user input and specific conditions, such as field values. This action automatically identifies the correct records and object type. e.g. 'Find all open opportunities created in the last 5 days sorted by created date.'
            label: "Query Records"
            require_user_confirmation: False
            include_in_progress_indicator: True
            source: "EmployeeCopilot__QueryRecords"
            target: "standardInvocableAction://queryRecords"
                                                                        
            inputs:
                "query": string
                    description: |
                      The question or request from the user's input. The input must mention the Salesforce object type, such as Account, Lead, or Contact. Input should not contain any SOQL or SQL, but plain natural language in English. Do not generate SQL or SOQL.
                    label: "query"
                    is_required: True
                    is_user_input: True
                "customizationInstructions": string
                    description: |
                      Custom instructions for the action from the user's input to optimize the query.
                    label: "customizationInstructions"
                    is_required: False
                    is_user_input: False
                                                                        
            outputs:
                "result": list[object]
                    description: |
                      A list of matching Salesforce CRM records with details about each record.
                    label: "result"
                    is_displayable: True
                    filter_from_agent: False
                    complex_data_type_name: "lightning__recordInfoType"

        UpdateAiGenActionItem:
            description: |
                Updates the status of an AI-generated action item record. Uses aiGenActionItemId and aiGenActionItemStatus to track the lifecycle and completion state of recommendations and tasks that the Sales agent generates.
            label: "Update AI-Generated Action Item Record"
            require_user_confirmation: False
            include_in_progress_indicator: False
            source: "SalesMgmt__UpdateAiGenActionItem"
            target: "standardInvocableAction://updateAiGenActionItem"
                                                                        
            inputs:
                "aiGenActionItemId": string
                    description: |
                      The unique identifier of the AI-Generated Action Item record to update.
                    label: "AI-Generated Action Item ID"
                    is_required: True
                    is_user_input: True
                "aiGenActionItemStatus": string
                    description: |
                      The status to assign the AI-Generated Action Item record.
                    label: "AI-Generated Action Item Status"
                    is_required: True
                    is_user_input: True
                                                                        
            outputs:
                "status": string
                    description: |
                      Indicates whether the AiGenActionItem update was successful or failed
                    label: "Status"
                    is_displayable: False
                    filter_from_agent: False
                "statusDetails": string
                    description: |
                      Additional information about the update operation, including any error messages or success details.
                    label: "Status Details"
                    is_displayable: False
                    filter_from_agent: False

